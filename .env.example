# Isi lalu simpan sebagai .env (jangan commit/share file .env asli)

DISCORD_TOKEN=isi_token_bot_discord_kamu
DISCORD_CLIENT_ID=isi_client_id_bot_kamu

# Opsional. Kosongkan jika yt-dlp sudah ada di PATH sistem (terinstall via pip/apt).
# Kalau hosting seperti Pterodactyl yang tidak izinkan install system-wide,
# download binary standalone yt-dlp lalu isi path-nya di sini, misal:
# YTDLP_PATH=./bin/yt-dlp
YTDLP_PATH=
